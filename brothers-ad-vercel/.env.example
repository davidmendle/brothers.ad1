# Replace with your private insurance intake API key.
INSURANCE_API_KEY=replace_me

# Required for admin dashboard authentication.
# Use a single email or a comma-separated list for multiple admin logins.
ADMIN_EMAILS=owner@example.com,operator@example.com
ADMIN_PASSWORD=replace_with_a_long_unique_password
ADMIN_JWT_SECRET=replace_with_a_long_random_secret_at_least_32_characters

# Optional: override the default 12 hour admin session lifetime in milliseconds.
ADMIN_SESSION_TTL_MS=43200000

# Optional: force secure cookies on or off. Leave unset in most environments.
# ADMIN_COOKIE_SECURE=true

# Replace with your real public website domain.
ALLOWED_WEBSITE_ORIGIN=https://YOUR-MAIN-WEBSITE-DOMAIN.com

# Local SQLite example for development.
# When BLOB_READ_WRITE_TOKEN is configured, intake records and files are stored durably in Vercel Blob.
# Keep SQLite locally for development and fallback-only use.
DATABASE_URL=file:./dev.db

# Live hosted OS domain.
OS_BASE_URL=https://brothers.ad

# Optional but recommended for production durability on Vercel.
# Create a private Blob store and let Vercel inject this token into the project environment.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Firebase Auth + Firestore RBAC
# Backend Firebase Admin credentials
FIREBASE_PROJECT_ID=brothers-restoration-website
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@brothers-restoration-website.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=replace_with_private_key_using_escaped_newlines
# Alternative: point to a local service-account JSON file or paste its raw JSON string.
# FIREBASE_SERVICE_ACCOUNT_JSON=.secrets/serviceAccountKey.json
# Alternative ADC path if your environment is already authenticated with Google Cloud credentials.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/application_default_credentials.json

# Frontend Firebase Web SDK config
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=brothers-restoration-website.firebaseapp.com
FIREBASE_STORAGE_BUCKET=brothers-restoration-website.firebasestorage.app
FIREBASE_APP_ID=1:80592032671:web:a4a236c46dda1eb12263aa
FIREBASE_MESSAGING_SENDER_ID=80592032671
FIREBASE_MEASUREMENT_ID=G-6Q0QNW5P10

# Access is intentionally short lived. The server caps Firebase OS sessions and trial grants at 48 hours.
FIREBASE_SESSION_TTL_MS=172800000

# Google sign-in is required by default. Keep the super-admin list owner-only.
FIREBASE_ALLOWED_SIGN_IN_PROVIDERS=google.com
FIREBASE_OWNER_ONLY_LOGIN=true
FIREBASE_ALLOWED_LOGIN_EMAILS=david@brothersrestoration.org

# Comma-separated list of emails that should auto-seed as Super Admins
SUPER_ADMIN_EMAILS=david@brothersrestoration.org
BLOCKED_ADMIN_EMAILS=chaim@brothersrestoration.org,reznikchaim@gmail.com

# Legacy bridges and derived password fallbacks are disabled by default for production safety.
# ENABLE_LEGACY_PROXY=false
# ALLOW_LEGACY_ADMIN_BRIDGE=false
# ALLOW_DERIVED_ADMIN_FALLBACK=false

# Optional but required if Super Admin should email invite links and individual access codes directly.
# Uses the Resend email API from the server.
RESEND_API_KEY=re_xxxxxxxxx
INVITE_FROM_EMAIL="Brothers OS <access@yourdomain.com>"
# INVITE_REPLY_TO_EMAIL=owner@yourdomain.com

# Public website bootstrap endpoint:
# GET /api/insurance-intake/public-config
# Health/readiness endpoint:
# GET /api/health
